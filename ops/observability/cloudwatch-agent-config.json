{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/syslog",
            "log_group_name": "/marketing-automation/systemd",
            "log_stream_name": "{instance_id}/syslog",
            "retention_in_days": 30
          },
          {
            "file_path": "/opt/marketing-automation/shared/artifacts/runtime.log",
            "log_group_name": "/marketing-automation/app",
            "log_stream_name": "{instance_id}/app",
            "retention_in_days": 30
          },
          {
            "file_path": "/opt/marketing-automation/shared/artifacts/publisher.log",
            "log_group_name": "/marketing-automation/publisher",
            "log_stream_name": "{instance_id}/publisher",
            "retention_in_days": 30
          }
        ]
      }
    }
  }
}
