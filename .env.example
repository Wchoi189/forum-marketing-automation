# Project root and storage
PROJECT_ROOT="/parent/marketing-automation"
ACTIVITY_LOG_PATH="/parent/marketing-automation/activity_log.json"
BOT_PROFILE_DIR="/parent/marketing-automation/ppomppu_profile"

# Forum and account
FORUM_PRIMARY_ID="ppomppu"
PPOMPPU_USER_ID="shareplan365"
PPOMPPU_USER_PW="CHANGE_ME"

# Runtime controls
OBSERVER_GAP_THRESHOLD="5"
RUN_INTERVAL_MINUTES="60"
MANUAL_OVERRIDE_ENABLED="true"
DRY_RUN_MODE="true"
# true = headless Chromium (default). On Linux, headed mode (false) requires a display (e.g. WSL: set DISPLAY or use xvfb-run).
BROWSER_HEADLESS="true"
# Playwright page.goto timeout for board navigation (ms). Default 30000. Raise if site is slow.
# BOT_NAV_TIMEOUT_MS="30000"
# Optional: override default desktop Chrome UA if the site returns 403 (bot/WAF). Copy a current UA from a real browser.
# BROWSER_USER_AGENT="Mozilla/5.0 ..."
PORT="3000"

# Publisher controls
# 1-based index of draft item to load from saved drafts (preview rows between items are skipped automatically)
PUBLISHER_DRAFT_ITEM_INDEX="1"
