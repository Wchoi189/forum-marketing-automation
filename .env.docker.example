# Docker environment — copy to .env.docker and fill in values
# Required
PPOMPPU_USER_ID=your_username
PPOMPPU_USER_PW=your_password
FORUM_PRIMARY_ID=ppomppu
PROJECT_ROOT=/app

# Optional — tune defaults
DRY_RUN_MODE=true
RUN_INTERVAL_MINUTES=60
MANUAL_OVERRIDE_ENABLED=true
PUBLISHER_DEBUG_SCREENSHOTS=false
PUBLISHER_DEBUG_TRACE=false
DEV_SKIP_BOT=false

# AI Advisor (optional)
# XAI_API_KEY=
# AI_ADVISOR_ENABLED=true

# NL Webhook (optional)
# NL_WEBHOOK_ENABLED=true
# NL_WEBHOOK_SECRET=

# Kakao Chatbot (optional)
# KAKAO_WEBHOOK_ENABLED=false
# KAKAO_ADMIN_KEY=
# OPENAI_API_KEY=
# KAKAO_AUTOREPLY_ENABLED=false
