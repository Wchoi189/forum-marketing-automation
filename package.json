{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "mcp:parser": "tsx mcp/parser-server.ts",
    "playbook:from-recorder": "node scripts/convert-recorder-to-playbook.mjs",
    "workflow:template": "node scripts/create-workflow-template.mjs",
    "scheduler:fixtures": "tsx scripts/generate_scheduler_signal_fixtures.ts",
    "scheduler:replay": "tsx scripts/scheduler_signal_replay.ts",
    "scheduler:replay:recent": "tsx scripts/scheduler_signal_replay.ts --window-days 14 --window-size 8 --history-limit 240 --output-dir artifacts/scheduler-replay/latest-recent",
    "scheduler:replay:runbook": "bash ops/systemd/scheduler-replay-report.sh",
    "publisher-history:parquet": "python3 scripts/publisher_history_jsonl_to_parquet.py",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "npm run lint && npm run test:unit && npm run test:integration && npm run test:mcp:parser",
    "test:unit": "tsx --test tests/unit/competitorAnalytics.test.ts tests/unit/controlPanelSync.test.ts tests/unit/schedulerSignals.test.ts",
    "test:mcp:parser": "tsx --test tests/integration/parser-mcp.integration.test.ts",
    "test:integration": "PROJECT_ROOT=/parent/marketing-automation FORUM_PRIMARY_ID=ppomppu PPOMPPU_USER_ID=test-user PPOMPPU_USER_PW=test-pass BOT_PROFILE_DIR=/tmp/ppomppu-profile ACTIVITY_LOG_PATH=/tmp/activity-log.json XAI_API_KEY=test-xai-key NL_WEBHOOK_SECRET=test-secret tsx --test tests/integration/api.integration.test.ts tests/integration/playbook-runner.integration.test.ts tests/integration/nlWebhook.test.ts"
  },
  "dependencies": {
    "@ui5/webcomponents-react": "^2.10.0",
    "@ui5/webcomponents": "^2.10.0",
    "@ui5/webcomponents-fiori": "^2.10.0",
    "@ui5/webcomponents-icons": "^2.10.0",
    "@google/genai": "^1.29.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.10.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
