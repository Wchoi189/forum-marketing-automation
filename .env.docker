# Docker environment — production defaults
# Secrets loaded from .env

# Required
PPOMPPU_USER_ID=your_ppomppu_username
PPOMPPU_USER_PW=your_ppomppu_password
FORUM_PRIMARY_ID=ppomppu
PROJECT_ROOT=/app

# Runtime controls
DRY_RUN_MODE=false
DEV_SKIP_BOT=false
RUN_INTERVAL_MINUTES=60
MANUAL_OVERRIDE_ENABLED=true
PUBLISHER_DEBUG_SCREENSHOTS=false
PUBLISHER_DEBUG_TRACE=false

# Search / AI APIs
TAVILY_API_KEY=your_tavily_api_key
EXA_API_KEY=your_exa_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
XAI_API_KEY=your_xai_api_key
OPENAI_API_KEY=your_openai_api_key
AI_ADVISOR_ENABLED=true
AI_ADVISOR_TIMEOUT_MS=8000

# NL Webhook
NL_WEBHOOK_ENABLED=true
SLACK_WEBHOOK_URL=your_slack_webhook_url
SLACK_OAUTH_TOKEN=your_slack_oauth_token
SLACK_APP_TOKEN=your_slack_app_token

# Kakao Chatbot
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key
KAKAO_ADMIN_KEY=your_kakao_admin_key
KAKAO_OPENBUILDER_BOT_ID=your_kakao_bot_id
KAKAO_MESSENGER_REST_API_KEY=your_kakao_messenger_rest_api_key
KAKAO_LOGIN_CLIENT_SECRET=your_kakao_login_client_secret
KAKAO_BIZ_CLIENT_SECRET=your_kakao_biz_client_secret
KAKAO_CHANNEL_ID=your_kakao_channel_id
KAKAO_SKILL_SECRET=your_kakao_skill_secret
KAKAO_BASE_URL=https://kapi.kakao.com/v2/api/talk/channels
KAKAO_WEBHOOK_ENABLED=true
KAKAO_AUTOREPLY_ENABLED=false
KAKAO_DB_ENABLED=true
KAKAO_DB_HOST=ocr-postgres
KAKAO_DB_PASSWORD=your_postgres_password
KAKAO_DB_USER=your_postgres_user
