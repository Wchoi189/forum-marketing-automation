{
  "python.envFile": "${workspaceFolder}/.env",
  "python.terminal.useEnvFile": true,
  "python.terminal.activateEnvironment": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,

  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.rulers": [100],
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  "js/ts.tsdk.path": "${workspaceFolder}/node_modules/typescript/lib",
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  "typescript.maxTsServerMemory": 8192,
  "search.exclude": {
    "**/activity_log.json": true,
    "**/artifacts/**": true,
    "**/.agent/**": true,
    "**/storage/**": true,
    "**/templates/**": true,
    "**/ppomppu_profile/**": true,
    "**/node_modules/**": true,
    "**/.qwen/**": true,
    "**/.npm/**": true,
    "**/.local/**": true,
    "**/.cache/**": true,
    "**/data/**": true,
    "**/.ai/**": true,
    "**/.venv/**": true,
    "**/dist/**": true,
    "**/.git/**": true,
    "**/kakaoauto-controller-preview/**": true,
    "**/mempalace*/**": true
  },
  "files.exclude": {
    "**/.qwen": true,
    "**/.npm": true,
    "**/.local": true,
    "**/.cache": true,
    "**/.ai": true
  },
  "files.watcherExclude": {
    "**/activity_log.json": true,
    "**/artifacts/**": true,
    "**/.agent/**": true,
    "**/storage/**": true,
    "**/templates/**": true,
    "**/ppomppu_profile/**": true,
    "**/.npm/**": true,
    "**/.local/**": true,
    "**/.cache/**": true,
    "**/data/**": true,
    "**/.venv/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/.git/**": true,
    "**/kakaoauto-controller-preview/**": true,
    "**/mempalace*/**": true
  },

  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.scrollback": 10000,
  "dbcode.connections": [
    {
      "connectionId": "LZXgK6TY6bDZJHqeBnA1W",
      "name": "competitor-ads.db",
      "driver": "sqlite",
      "connectionType": "socket",
      "socket": "marketing-automation/artifacts/competitor-ads/competitor-ads.db",
      "readOnly": false,
      "role": "development",
      "postConnectionSqlType": "inline",
      "driverOptions": {
        "extensions": []
      },
      "idleTimeout": 0,
      "introspection": {
        "progressive": false
      }
    }
  ]
}
