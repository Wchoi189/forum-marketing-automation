{
  "plan_id": "planning-execution-loop-v1",
  "purpose": "Define a single, repeatable execution loop for planning and implementation to prevent drift.",
  "design_intent": "Make every change pass through the same intake -> plan -> implement -> verify -> update -> handover loop, with explicit artifacts and status updates.",
  "change_impact": "Changes affect how all planning artifacts and progress statuses are updated; skipping steps risks stale or duplicated plans.",
  "scope": "planning_and_implementation",
  "loop": {
    "stages": [
      {
        "stage": "intake",
        "goal": "Capture the request, link it to existing specs/plans, and define the minimal scope.",
        "inputs": ["request", "related_specs", "related_plans"],
        "outputs": ["scope_statement", "linked_refs"],
        "exit_criteria": ["scope_statement_complete", "refs_linked"]
      },
      {
        "stage": "diagnose",
        "goal": "Identify drift, duplication, or missing contracts before changing anything.",
        "inputs": ["current_planning_inventory", "status_trackers"],
        "outputs": ["drift_findings", "risk_notes", "drift_report"],
        "exit_criteria": ["drift_findings_logged"]
      },
      {
        "stage": "plan",
        "goal": "Choose the execution tracker, write acceptance criteria, and list the smallest deliverables.",
        "inputs": ["scope_statement", "drift_findings"],
        "outputs": ["plan_update", "acceptance", "context_pack", "verification_budget"],
        "exit_criteria": ["plan_update_saved", "acceptance_defined", "context_pack_saved", "verification_budget_defined"]
      },
      {
        "stage": "implement",
        "goal": "Apply the smallest change set that satisfies the acceptance criteria.",
        "inputs": ["plan_update"],
        "outputs": ["code_or_doc_changes"],
        "exit_criteria": ["changes_complete"]
      },
      {
        "stage": "verify",
        "goal": "Run required checks and confirm behavior matches acceptance criteria.",
        "inputs": ["acceptance", "verification_steps"],
        "outputs": ["verification_results"],
        "exit_criteria": ["checks_complete", "results_logged"]
      },
      {
        "stage": "update_brain",
        "goal": "Update planning docs, status checklists, and hard copy snapshot.",
        "inputs": ["code_or_doc_changes", "verification_results"],
        "outputs": ["status_updates", "hard_copy_snapshot", "archive_actions", "archive_debt_report"],
        "exit_criteria": ["status_updated", "snapshot_updated", "archive_actions_logged", "archive_debt_cleared"]
      },
      {
        "stage": "handover",
        "goal": "Record what changed, why, risks, and the next exact step.",
        "inputs": ["status_updates"],
        "outputs": ["handover_note"],
        "exit_criteria": ["handover_note_saved"]
      }
    ]
  },
  "artifacts": {
    "required": [
      "context_pack",
      "verification_budget",
      "spec_or_plan_update",
      "status_update",
      "verification_results",
      "hard_copy_snapshot"
    ],
    "optional": ["risk_note", "decision_log", "drift_report"]
  },
  "status_rules": {
    "single_tracker_per_task": true,
    "allowed_trackers": ["plans/sprints", "archive/plans/tasks"],
    "duplication_policy": "Do not mirror the same task across multiple trackers. Link instead."
  },
  "audit_policy": {
    "mode": "event_driven",
    "triggers": ["structural_move", "status_change", "new_plan_or_spec", "archive_move"],
    "prohibitions": ["periodic_full_scans", "duplicate_tracker_reviews_without_trigger"]
  },
  "regression_policy": {
    "verification_budget_required": true,
    "max_steps": 3,
    "defaults": ["lint", "targeted_test"],
    "allow_manual": true
  },
  "archive_policy": {
    "required_on_closeout": true,
    "debt_not_allowed": true,
    "definition": "Any plan/task marked done must be moved to .planning/spec-kit/archive in the same loop.",
    "debt_field": "archive_debt"
  },
  "hard_copy": {
    "snapshot_dir": "plans/snapshots",
    "update_triggers": ["new_plan_or_spec", "status_change", "structural_move"],
    "retention": "Keep latest snapshot and the first snapshot per quarter."
  },
  "templates": {
    "context_pack": "templates/context-pack.md",
    "drift_report": "templates/drift-report.md"
  },
  "references": {
    "planning_root": ".planning/spec-kit",
    "runtime_execution_contract": "../specs/execution-loop.contract.json",
    "decision_rules": "../specs/decision-rules.json",
    "planning_guidance": "README.md"
  }
}
