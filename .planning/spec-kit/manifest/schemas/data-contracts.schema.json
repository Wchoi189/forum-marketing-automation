{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ppomppu-ott-bot/specs/data-contracts.schema.json",
  "title": "DataContracts",
  "definitions": {
    "post": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "author", "date", "views", "isNotice"],
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "views": { "type": "integer", "minimum": 0 },
        "isNotice": { "type": "boolean" }
      }
    },
    "activityLog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "current_gap_count",
        "last_post_timestamp",
        "top_competitor_names",
        "view_count_of_last_post",
        "status",
        "all_posts"
      ],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "current_gap_count": { "type": "integer", "minimum": 0 },
        "last_post_timestamp": { "type": "string" },
        "top_competitor_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "view_count_of_last_post": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["safe", "unsafe", "error"] },
        "all_posts": {
          "type": "array",
          "items": { "$ref": "#/definitions/post" }
        },
        "error": { "type": "string" },
        "gap_threshold_min": { "type": "integer", "minimum": 1, "maximum": 50 }
      }
    },
    "activityLogArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/activityLog" }
    },
    "competitorStat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "frequency", "avgViews"],
      "properties": {
        "author": { "type": "string" },
        "frequency": { "type": "integer", "minimum": 0 },
        "avgViews": { "type": "integer", "minimum": 0 }
      }
    },
    "competitorStatsArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/competitorStat" }
    },
    "boardStats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turnoverRate", "shareOfVoice"],
      "properties": {
        "turnoverRate": {
          "oneOf": [
            { "type": "number" },
            { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" }
          ]
        },
        "shareOfVoice": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "publisherHistoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "success", "force", "message"],
      "properties": {
        "at": { "type": "string", "format": "date-time" },
        "success": { "type": "boolean" },
        "force": { "type": "boolean" },
        "message": { "type": "string" },
        "runId": { "type": "string", "minLength": 1 },
        "artifactDir": { "type": ["string", "null"] },
        "decision": {
          "type": "string",
          "enum": [
            "gap_policy",
            "observer_error",
            "manual_override_disabled",
            "published_verified",
            "dry_run",
            "publisher_error"
          ]
        }
      }
    },
    "publisherHistoryArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/publisherHistoryEntry" }
    },
    "draftItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "timestamp", "id"],
      "properties": {
        "title": { "type": "string" },
        "timestamp": { "type": "string" },
        "id": { "type": "string" }
      }
    },
    "draftsArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/draftItem" }
    },
    "publisherRunRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "force": { "type": "boolean" }
      }
    },
    "observerRunResponse": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "error": { "type": "string" },
        "log": { "$ref": "#/definitions/activityLog" }
      }
    },
    "publisherRunResponse": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "message": { "type": "string" },
        "error": { "type": "string" },
        "log": { "$ref": "#/definitions/activityLog" },
        "runId": { "type": "string", "minLength": 1 },
        "artifactDir": { "type": ["string", "null"] },
        "decision": {
          "type": "string",
          "enum": [
            "gap_policy",
            "observer_error",
            "manual_override_disabled",
            "published_verified",
            "dry_run",
            "publisher_error"
          ]
        }
      }
    },
    "observerControls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "minPreVisitDelayMs",
        "maxPreVisitDelayMs",
        "minIntervalBetweenRunsMs"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "minPreVisitDelayMs": { "type": "integer", "minimum": 0, "maximum": 120000 },
        "maxPreVisitDelayMs": { "type": "integer", "minimum": 0, "maximum": 120000 },
        "minIntervalBetweenRunsMs": { "type": "integer", "minimum": 0, "maximum": 3600000 },
        "gapThresholdMin": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "description": "Effective minimum gap (posts) after persisted/env/spec precedence."
        },
        "gapPersistedOverride": {
          "description": "File-persisted override; null means use env (if set) then spec baseline.",
          "oneOf": [{ "type": "integer", "minimum": 1, "maximum": 50 }, { "type": "null" }]
        },
        "gapThresholdSpecBaseline": { "type": "integer", "minimum": 1, "maximum": 50 },
        "gapUsesEnvOverride": { "type": "boolean" }
      }
    },
    "publisherControls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draftItemIndex"],
      "properties": {
        "draftItemIndex": { "type": "integer", "minimum": 1, "maximum": 50 }
      }
    },
    "autoPublisherControls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "baseIntervalMinutes",
        "effectiveIntervalMinutes",
        "quietHoursStart",
        "quietHoursEnd",
        "quietHoursMultiplier",
        "activeHoursStart",
        "activeHoursEnd",
        "activeHoursMultiplier",
        "trendAdaptiveEnabled",
        "trendWindowDays",
        "trendRecalibrationDays",
        "scheduleJitterPercent",
        "scheduleJitterMode",
        "targetPublishIntervalMinutes",
        "running"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "baseIntervalMinutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "effectiveIntervalMinutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "quietHoursStart": { "type": "integer", "minimum": 0, "maximum": 23 },
        "quietHoursEnd": { "type": "integer", "minimum": 0, "maximum": 23 },
        "quietHoursMultiplier": { "type": "number", "minimum": 0.2, "maximum": 5 },
        "activeHoursStart": { "type": "integer", "minimum": 0, "maximum": 23 },
        "activeHoursEnd": { "type": "integer", "minimum": 0, "maximum": 23 },
        "activeHoursMultiplier": { "type": "number", "minimum": 0.2, "maximum": 5 },
        "trendAdaptiveEnabled": { "type": "boolean" },
        "trendWindowDays": { "type": "integer", "minimum": 1, "maximum": 60 },
        "trendRecalibrationDays": { "type": "integer", "minimum": 1, "maximum": 30 },
        "scheduleJitterPercent": { "type": "integer", "minimum": 0, "maximum": 50 },
        "scheduleJitterMode": { "type": "string", "enum": ["none", "uniform"] },
        "targetPublishIntervalMinutes": { "type": "integer", "minimum": 0, "maximum": 1440 },
        "running": { "type": "boolean" }
      }
    },
    "controlPanelResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preset", "observer", "publisher", "autoPublisher"],
      "properties": {
        "preset": { "type": "string", "enum": ["balanced", "night-safe", "day-aggressive"] },
        "observer": { "$ref": "#/definitions/observerControls" },
        "publisher": { "$ref": "#/definitions/publisherControls" },
        "autoPublisher": { "$ref": "#/definitions/autoPublisherControls" }
      }
    },
    "controlPanelRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preset": { "type": "string", "enum": ["balanced", "night-safe", "day-aggressive"] },
        "observer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "minPreVisitDelayMs": { "type": "integer" },
            "maxPreVisitDelayMs": { "type": "integer" },
            "minIntervalBetweenRunsMs": { "type": "integer" },
            "gapPersistedOverride": {
              "description": "Set to integer to persist; null clears file override.",
              "oneOf": [{ "type": "integer", "minimum": 1, "maximum": 50 }, { "type": "null" }]
            }
          }
        },
        "publisher": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "draftItemIndex": { "type": "integer" }
          }
        },
        "autoPublisher": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "baseIntervalMinutes": { "type": "integer" },
            "quietHoursStart": { "type": "integer" },
            "quietHoursEnd": { "type": "integer" },
            "quietHoursMultiplier": { "type": "number" },
            "activeHoursStart": { "type": "integer" },
            "activeHoursEnd": { "type": "integer" },
            "activeHoursMultiplier": { "type": "number" },
            "trendAdaptiveEnabled": { "type": "boolean" },
            "trendWindowDays": { "type": "integer" },
            "trendRecalibrationDays": { "type": "integer" },
            "scheduleJitterPercent": { "type": "integer" },
            "scheduleJitterMode": { "type": "string", "enum": ["none", "uniform"] },
            "targetPublishIntervalMinutes": { "type": "integer" }
          }
        }
      }
    },
    "trendHourlyBucket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hour", "avgNewPostsPerHour"],
      "properties": {
        "hour": { "type": "integer", "minimum": 0, "maximum": 23 },
        "avgNewPostsPerHour": { "type": "number", "minimum": 0 }
      }
    },
    "competitorAnalyticsDataHealth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshotCount",
        "medianGapHours",
        "largeGapWarning",
        "fromIso",
        "toIso",
        "bucket"
      ],
      "properties": {
        "snapshotCount": { "type": "integer", "minimum": 0 },
        "medianGapHours": { "type": ["number", "null"] },
        "largeGapWarning": { "type": "boolean" },
        "fromIso": { "type": "string" },
        "toIso": { "type": "string" },
        "bucket": { "type": "string", "enum": ["hour", "day", "week"] }
      }
    },
    "competitorAnalyticsSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "postsInRange", "postsPerDay", "totalViews", "rank"],
      "properties": {
        "author": { "type": "string" },
        "postsInRange": { "type": "integer", "minimum": 0 },
        "postsPerDay": { "type": "number" },
        "totalViews": { "type": "integer", "minimum": 0 },
        "rank": { "type": "integer", "minimum": 1 }
      }
    },
    "competitorAnalyticsHeatmapCell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dayOfWeek", "hour", "count"],
      "properties": {
        "dayOfWeek": { "type": "integer", "minimum": 0, "maximum": 6 },
        "hour": { "type": "integer", "minimum": 0, "maximum": 23 },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "competitorAnalyticsBotSignals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "author",
        "postCount",
        "interArrivalCv",
        "clockAlignmentScore",
        "hourEntropy",
        "circadianUniformity",
        "burstMaxIn6h",
        "burstRatio",
        "heuristicTier"
      ],
      "properties": {
        "author": { "type": "string" },
        "postCount": { "type": "integer", "minimum": 0 },
        "interArrivalCv": { "type": ["number", "null"] },
        "clockAlignmentScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "hourEntropy": { "type": "number", "minimum": 0 },
        "circadianUniformity": { "type": "number", "minimum": 0, "maximum": 1 },
        "burstMaxIn6h": { "type": "integer", "minimum": 0 },
        "burstRatio": { "type": "number", "minimum": 0 },
        "heuristicTier": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "competitorAnalyticsPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataHealth",
        "timeSeries",
        "seriesAuthors",
        "summary",
        "heatmap",
        "botSignals",
        "disclaimer"
      ],
      "properties": {
        "dataHealth": { "$ref": "#/definitions/competitorAnalyticsDataHealth" },
        "timeSeries": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "seriesAuthors": { "type": "array", "items": { "type": "string" } },
        "summary": {
          "type": "array",
          "items": { "$ref": "#/definitions/competitorAnalyticsSummaryRow" }
        },
        "heatmap": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "cells"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["post_date_parsed", "snapshot_hour_only"]
            },
            "cells": {
              "type": "array",
              "items": { "$ref": "#/definitions/competitorAnalyticsHeatmapCell" }
            }
          }
        },
        "botSignals": {
          "type": "array",
          "items": { "$ref": "#/definitions/competitorAnalyticsBotSignals" }
        },
        "disclaimer": { "type": "string" }
      }
    },
    "trendInsights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "windowDays",
        "referenceBaseIntervalMinutes",
        "trendAdaptiveEnabled",
        "recentSnapshotCount",
        "pairSampleCount",
        "avgNewPostsPerHour",
        "volatility",
        "confidence",
        "confidenceReason",
        "trendMultiplier",
        "multiplierBand",
        "recommendedIntervalMinutesQuiet",
        "recommendedIntervalMinutesActive",
        "hourlyProfile",
        "explanation",
        "precedenceNote"
      ],
      "properties": {
        "windowDays": { "type": "integer", "minimum": 1, "maximum": 60 },
        "referenceBaseIntervalMinutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "trendAdaptiveEnabled": { "type": "boolean" },
        "recentSnapshotCount": { "type": "integer", "minimum": 0 },
        "pairSampleCount": { "type": "integer", "minimum": 0 },
        "avgNewPostsPerHour": { "type": "number", "minimum": 0 },
        "volatility": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidenceReason": {
          "type": "string",
          "enum": [
            "insufficient_snapshots",
            "insufficient_pairs",
            "empirical_window",
            "adaptive_disabled"
          ]
        },
        "trendMultiplier": { "type": "number", "minimum": 0.65, "maximum": 1.6 },
        "multiplierBand": {
          "type": "string",
          "enum": ["very_active", "active", "balanced", "quiet", "very_quiet", "unknown"]
        },
        "recommendedIntervalMinutesQuiet": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "recommendedIntervalMinutesActive": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "hourlyProfile": {
          "type": "array",
          "minItems": 24,
          "maxItems": 24,
          "items": { "$ref": "#/definitions/trendHourlyBucket" }
        },
        "explanation": { "type": "string" },
        "precedenceNote": { "type": "string" }
      }
    }
  }
}
