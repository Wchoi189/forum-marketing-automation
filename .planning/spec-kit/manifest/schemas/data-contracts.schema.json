{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ppomppu-ott-bot/specs/data-contracts.schema.json",
  "title": "DataContracts",
  "definitions": {
    "post": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "author", "date", "views", "isNotice"],
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "views": { "type": "integer", "minimum": 0 },
        "isNotice": { "type": "boolean" }
      }
    },
    "activityLog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "current_gap_count",
        "last_post_timestamp",
        "top_competitor_names",
        "view_count_of_last_post",
        "status",
        "all_posts"
      ],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "current_gap_count": { "type": "integer", "minimum": 0 },
        "last_post_timestamp": { "type": "string" },
        "top_competitor_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "view_count_of_last_post": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["safe", "unsafe", "error"] },
        "all_posts": {
          "type": "array",
          "items": { "$ref": "#/definitions/post" }
        },
        "error": { "type": "string" }
      }
    },
    "activityLogArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/activityLog" }
    },
    "competitorStat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "frequency", "avgViews"],
      "properties": {
        "author": { "type": "string" },
        "frequency": { "type": "integer", "minimum": 0 },
        "avgViews": { "type": "integer", "minimum": 0 }
      }
    },
    "competitorStatsArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/competitorStat" }
    },
    "boardStats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turnoverRate", "shareOfVoice"],
      "properties": {
        "turnoverRate": {
          "oneOf": [
            { "type": "number" },
            { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" }
          ]
        },
        "shareOfVoice": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "draftItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "timestamp", "id"],
      "properties": {
        "title": { "type": "string" },
        "timestamp": { "type": "string" },
        "id": { "type": "string" }
      }
    },
    "draftsArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/draftItem" }
    },
    "publisherRunRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "force": { "type": "boolean" }
      }
    },
    "observerRunResponse": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "error": { "type": "string" },
        "log": { "$ref": "#/definitions/activityLog" }
      }
    },
    "publisherRunResponse": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "message": { "type": "string" },
        "error": { "type": "string" },
        "log": { "$ref": "#/definitions/activityLog" }
      }
    }
  }
}
