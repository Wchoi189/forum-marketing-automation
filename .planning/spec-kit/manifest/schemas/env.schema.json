{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ppomppu-ott-bot/specs/env.schema.json",
  "title": "EnvContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "PROJECT_ROOT",
    "FORUM_PRIMARY_ID",
    "PPOMPPU_USER_ID",
    "PPOMPPU_USER_PW",
    "BOT_PROFILE_DIR",
    "ACTIVITY_LOG_PATH"
  ],
  "properties": {
    "PROJECT_ROOT": {
      "type": "string",
      "pattern": "^/"
    },
    "FORUM_PRIMARY_ID": {
      "type": "string",
      "enum": ["ppomppu"]
    },
    "PPOMPPU_USER_ID": {
      "type": "string",
      "minLength": 1
    },
    "PPOMPPU_USER_PW": {
      "type": "string",
      "minLength": 1
    },
    "BOT_PROFILE_DIR": {
      "type": "string",
      "minLength": 1
    },
    "ACTIVITY_LOG_PATH": {
      "type": "string",
      "minLength": 1
    },
    "OBSERVER_GAP_THRESHOLD": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 5
    },
    "RUN_INTERVAL_MINUTES": {
      "type": "integer",
      "minimum": 5,
      "maximum": 1440,
      "default": 60
    },
    "MANUAL_OVERRIDE_ENABLED": {
      "type": "boolean",
      "default": true
    },
    "DRY_RUN_MODE": {
      "type": "boolean",
      "default": true
    },
    "BROWSER_HEADLESS": {
      "type": "boolean",
      "default": true
    },
    "FORUMS_ENABLED": {
      "type": "string"
    },
    "FORUM_PPOMPPU_USER_ID": {
      "type": "string"
    },
    "FORUM_PPOMPPU_USER_PW": {
      "type": "string"
    }
  }
}
