        "minimum_run_interval",
        "fail_closed_default"
      ]
    },
    {
      "id": "AR-003",
      "risk": "unsafe forced publishing without traceability",
      "mitigation": [
        "manual_override_enabled_flag",
        "audit_event_required",
        "operator_id_capture_for_override"
      ]
    },
    {
      "id": "AR-004",
      "risk": "schema drift between UI/backend/bot",
      "mitigation": [
        "single_contract_source",
        "startup_schema_validation",
        "contract_version_pin"
      ]
