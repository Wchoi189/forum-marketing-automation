{
  "contract_id": "express-api-v1",
  "base_path": "/api",
  "routes": [
    {
      "method": "GET",
      "path": "/publisher-history",
      "description": "Recent auto/manual publisher run outcomes with ISO timestamps",
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/publisherHistoryArray"
    },
    {
      "method": "GET",
      "path": "/logs",
      "description": "Fetch ordered activity logs",
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/activityLogArray"
    },
    {
      "method": "GET",
      "path": "/analytics/competitors",
      "description": "Snapshot-based competitor EDA: time series, summary, heatmap, bot-likeness heuristics",
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/competitorAnalyticsPayload"
    },
    {
      "method": "GET",
      "path": "/competitor-stats",
      "description": "Fetch top competitor stats over recent window",
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/competitorStatsArray"
    },
    {
      "method": "GET",
      "path": "/board-stats",
      "description": "Fetch board turnover and share-of-voice metrics",
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/boardStats"
    },
    {
      "method": "GET",
      "path": "/trend-insights",
      "description": "Trend analytics from activity logs and advisory scheduler interval hints",
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/trendInsights"
    },
    {
      "method": "GET",
      "path": "/drafts",
      "description": "Fetch available drafts for UI visualization",
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/draftsArray"
    },
    {
      "method": "POST",
      "path": "/run-observer",
      "description": "Trigger observer module",
      "request_schema_ref": null,
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/observerRunResponse"
    },
    {
      "method": "POST",
      "path": "/run-publisher",
      "description": "Trigger publisher module with optional force override",
      "request_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/publisherRunRequest",
      "response_schema_ref": "../manifest/schemas/data-contracts.schema.json#/definitions/publisherRunResponse"
    }
  ]
}
