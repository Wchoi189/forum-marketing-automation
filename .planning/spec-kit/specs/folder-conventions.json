{
  "convention_id": "folder-conventions-v1",
  "roots": {
    "planning": ".planning/spec-kit",
    "agent": ".agent",
    "runtime": "."
  },
  "rules": [
    {
      "id": "planning_ai_only",
      "path": ".planning/spec-kit",
      "allowed_formats": ["json", "yaml", "md", "txt"],
      "notes": "ai-primary docs with a compact reviewer pack; markdown limited to constraints and short references"
    },
    {
      "id": "planning_semantic_specs",
      "path": ".planning/spec-kit/specs",
      "allowed_formats": ["json", "md"],
      "notes": "each spec should include intent fields (purpose/design_intent/change_impact) with concise semantics"
    },
    {
      "id": "agent_state_container",
      "path": ".agent/state",
      "allowed_formats": ["json"],
      "notes": "state snapshots and resumable context"
    },
    {
      "id": "agent_contracts_container",
      "path": ".agent/contracts",
      "allowed_formats": ["json"],
      "notes": "canonical data and API contracts"
    },
    {
      "id": "handover_container",
      "path": ".agent/session-handovers",
      "allowed_formats": ["json"],
      "file_pattern": "^handover-\\d{8}-\\d{4}\\.json$"
    }
  ]
}
